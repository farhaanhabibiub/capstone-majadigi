PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/majadigi_auth

# URL backend yang dipakai di email verifikasi.
# HARUS public URL saat dites dari email sungguhan.
APP_BASE_URL=http://localhost:5000

# Optional
WEB_LOGIN_URL=http://localhost:3000/login
MOBILE_LOGIN_DEEP_LINK=majadigi://login

# Pisahkan dengan koma kalau lebih dari satu
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000

MAIL_FROM=Majadigi <yourgmail@gmail.com>
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

EMAIL_TOKEN_TTL_HOURS=24